{
  "name": "coconut-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "NODE_OPTIONS='--disable-warning=DEP0169' expo start",
    "start:dev": "NODE_OPTIONS='--disable-warning=DEP0169' expo start --dev-client",
    "start:device": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null || echo localhost) CI=false NODE_OPTIONS='--disable-warning=DEP0169' expo start",
    "android": "NODE_OPTIONS='--disable-warning=DEP0169' expo run:android",
    "ios": "NODE_OPTIONS='--disable-warning=DEP0169' expo run:ios",
    "ios:device": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null || echo localhost) CI=false NODE_OPTIONS='--disable-warning=DEP0169' npx expo run:ios --device",
    "ios:dev": "APP_VARIANT=dev NODE_OPTIONS='--disable-warning=DEP0169' expo run:ios",
    "ios:dev:device": "APP_VARIANT=dev REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null || echo localhost) CI=false NODE_OPTIONS='--disable-warning=DEP0169' npx expo run:ios --device",
    "web": "NODE_OPTIONS='--disable-warning=DEP0169' expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@clerk/expo": "^3.0.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@stripe/stripe-terminal-react-native": "^0.0.1-beta.29",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~55.0.5",
    "expo-auth-session": "^55.0.9",
    "expo-build-properties": "^55.0.9",
    "expo-clipboard": "^55.0.8",
    "expo-constants": "^55.0.7",
    "expo-contacts": "~55.0.9",
    "expo-crypto": "~55.0.9",
    "expo-dev-client": "^55.0.11",
    "expo-device": "~55.0.12",
    "expo-document-picker": "^55.0.8",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.8",
    "expo-image-picker": "^55.0.11",
    "expo-linking": "^55.0.7",
    "expo-local-authentication": "~55.0.9",
    "expo-notifications": "~55.0.16",
    "expo-router": "^55.0.4",
    "expo-secure-store": "^55.0.8",
    "expo-sms": "~55.0.9",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-updates": "~55.0.18",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-plaid-link-sdk": "^12.8.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "eas-cli": "^18.3.0",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.13",
    "typescript": "~5.9.2"
  },
  "private": true
}
