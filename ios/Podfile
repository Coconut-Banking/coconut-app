# Set by expo-router. This enables Fabric-only features from react-native-screens
ENV['RNS_GAMMA_ENABLED'] ||= '1'
require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']

  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_HERMES_V1_ENABLED'] ||= '1' if podfile_properties['expo.useHermesV1'] == 'true'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

# Dev variant uses CoconutDev project/target; production uses Coconut.
# Triggered by APP_VARIANT=dev|development (local) or EAS_BUILD_PROFILE=development*.
app_variant = (ENV['APP_VARIANT'] || '').downcase
is_dev_variant = ['dev', 'development'].include?(app_variant) ||
  ENV['EAS_BUILD_PROFILE'] == 'development' ||
  ENV['EAS_BUILD_PROFILE'] == 'development-simulator'
ios_target_name = is_dev_variant ? 'CoconutDev' : 'Coconut'

project ios_target_name

target ios_target_name do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    # Clerk: Resolve SPM packages synchronously during pod install
    # This ensures packages are downloaded before the user opens Xcode
    # We wait until the end of post_install to ensure workspace is fully written
    at_exit do
      workspace_path = File.join(__dir__, "#{ios_target_name}.xcworkspace")
      if File.exist?(workspace_path)
        puts ""
        puts "📦 [Clerk] Resolving Swift Package dependencies..."
        puts "   This may take a minute on first run..."
        # Use backticks to capture output and check exit status
        output = `xcodebuild -resolvePackageDependencies -workspace "#{workspace_path}" -scheme "#{ios_target_name}" 2>&1`
        if $?.success?
          puts "✅ [Clerk] Swift Package dependencies resolved successfully"
        else
          puts "⚠️  [Clerk] SPM resolution output:"
          puts output.lines.last(10).join
        end
        puts ""
      end
    end

    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # When hermes-engine is built from source (e.g. prebuilt tarball unavailable),
    # hermes.h includes <jsi/hermes-interfaces.h> which only exists in hermes-engine/API/jsi.
    # Copy it into ReactCommon/jsi so the CMake build can find it, and symlink into Pod headers.
    hermes_jsi_src = File.join(__dir__, 'Pods', 'hermes-engine', 'API', 'jsi', 'jsi', 'hermes-interfaces.h')
    if File.exist?(hermes_jsi_src)
      rn_jsi_dst = File.join(__dir__, '..', 'node_modules', 'react-native', 'ReactCommon', 'jsi', 'jsi', 'hermes-interfaces.h')
      FileUtils.cp(hermes_jsi_src, rn_jsi_dst) unless File.exist?(rn_jsi_dst)
      %w[Public Private].each do |vis|
        dst = File.join(__dir__, 'Pods', 'Headers', vis, 'React-jsi', 'jsi', 'hermes-interfaces.h')
        FileUtils.ln_sf(hermes_jsi_src, dst) unless File.exist?(dst)
      end
    end
  end
end
